{% props href = false, color = 'primary', size = 'regular' %}

{% set style_badge = html_cva(
    base: 'inline-flex items-center rounded-md border font-medium transition-colors',
    variants: {
        color: {
            primary: 'text-primary-700 bg-primary-500/10 border-primary-500/20 dark:text-primary-300 dark:bg-primary-400/10 dark:border-primary-400/20',
            gray: 'text-zinc-600 bg-zinc-500/10 border-zinc-500/20 dark:text-zinc-300 dark:bg-zinc-400/10 dark:border-zinc-400/15',
        },
        size: {
            regular: 'px-2 py-0.5 text-sm',
            sm: 'px-1.5 py-0.5 text-xs',
        },
        hoverable: {
            'true': 'hover:bg-primary-500/20 dark:hover:bg-primary-400/20',
            'false': '',
        },
    },
) %}

<{{ href ? 'a' : 'span' }} class="{{ style_badge.apply({color, size, hoverable: href ? 'true' : 'false'}, attributes.render('class') ?? '') }}" {{
    attributes.defaults({href}) }}>
    {{- block('content') -}}
</{{ href ? 'a' : 'span' }}>
