{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "~8.5.0",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-mbstring": "*",
        "cuyz/valinor": "^2.4.0",
        "cuyz/valinor-bundle": "^2.3.0",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.7",
        "easycorp/easyadmin-bundle": "^5.0.11",
        "knplabs/knp-menu-bundle": "^3.7",
        "league/commonmark": "^2.8.2",
        "league/flysystem-bundle": "^3.7.0",
        "league/uri": ">=7.8.1",
        "martin-georgiev/postgresql-for-doctrine": "^4.6",
        "phpdocumentor/reflection-docblock": "^5.6",
        "phpstan/phpdoc-parser": "^2.3.2",
        "predis/predis": "^3.4",
        "presta/sitemap-bundle": "^4.3",
        "sensiolabs/minify-bundle": "^1.2",
        "symfony/asset": "8.1.*",
        "symfony/asset-mapper": "8.1.*",
        "symfony/clock": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/emoji": "8.1.*",
        "symfony/flex": "^2.11",
        "symfony/framework-bundle": "8.1.*",
        "symfony/http-client": "8.1.*",
        "symfony/messenger": "8.1.*",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/options-resolver": "8.1.*",
        "symfony/property-access": "8.1.*",
        "symfony/property-info": "8.1.*",
        "symfony/rate-limiter": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/serializer": "8.1.*",
        "symfony/stimulus-bundle": "^3.2",
        "symfony/twig-bundle": "8.1.*",
        "symfony/uid": "8.1.*",
        "symfony/ux-icons": "^3.2",
        "symfony/ux-leaflet-map": "^3.2",
        "symfony/ux-map": "^3.2",
        "symfony/ux-turbo": "^3.2",
        "symfony/ux-twig-component": "^3.2",
        "symfony/validator": "8.1.*",
        "symfony/web-link": "8.1.*",
        "symfony/yaml": "8.1.*",
        "symfonycasts/tailwind-bundle": "^0.13.0",
        "twig/extra-bundle": "^3.24.0",
        "twig/html-extra": "^3.24.0",
        "twig/intl-extra": "^3.26.0",
        "twig/twig": "^3.27.1"
    },
    "require-dev": {
        "deptrac/deptrac": "^4.6",
        "kocal/oxc-bundle": "^1.0",
        "kocal/phpstan-symfony-ux": "^1.3.0",
        "phpstan/phpstan": "^2.2.1",
        "phpstan/phpstan-doctrine": "^2.0.23",
        "phpstan/phpstan-symfony": "^2.0.19",
        "phpunit/phpunit": "^13",
        "rector/rector": "^2.4.5",
        "symfony/browser-kit": "8.1.*",
        "symfony/css-selector": "8.1.*",
        "symfony/debug-bundle": "8.1.*",
        "symfony/maker-bundle": "^1.67.0",
        "symfony/stopwatch": "8.1.*",
        "symfony/web-profiler-bundle": "8.1.*",
        "symplify/easy-coding-standard": "^13.1",
        "vincentlanglet/twig-cs-fixer": "^3.14",
        "zenstruck/foundry": "^2.10.1"
    },
    "config": {
        "platform": {
            "php": "8.5"
        },
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true,
        "optimize-autoloader": true,
        "bump-after-update": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\PHPStan\\": "tools/phpstan/src/",
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*",
        "symfony/polyfill-php85": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd",
            "tailwind:build --minify": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "8.1.*"
        }
    }
}
